# Obrigatório: gere com `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`
SECRET_KEY=your-secret-key-here

# Modo debug (True apenas em desenvolvimento)
DEBUG=True

# URL de conexão com PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/custodia

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens CORS permitidas (separados por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
