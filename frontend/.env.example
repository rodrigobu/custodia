# URL base da API backend (sem barra final)
# Desenvolvimento: http://localhost:8000/api
# Produção (Vercel com proxy): /api
# Produção (direto): https://custodia-uhft.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Cloudinary - Upload de imagens (free tier)
# Crie uma conta em https://cloudinary.com e configure um unsigned upload preset
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=seu_upload_preset
